---
interface Props {
  src: string;
  title?: string;
}

const { src, title = "PDF" } = Astro.props;
---

<div class="not-content my-6 overflow-hidden rounded-xl border border-(--border-color) shadow-sm">
  <div class="flex items-center gap-3 px-5 py-4">
    <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-(--primary)/10">
      <span class="i-material-symbols:description text-2xl" style="color:var(--primary)"></span>
    </div>
    <div class="min-w-0 flex-1">
      <div class="truncate font-medium text-sm">{title}</div>
      <div class="text-xs text-(--text-secondary) mt-0.5">PDF 文档</div>
    </div>
    <div class="flex shrink-0 gap-2">
      <a href={src} target="_blank"
        class="flex items-center gap-1 rounded-lg px-3 py-2 text-sm font-medium transition-colors border border-(--border-color) hover:bg-(--primary) hover:text-white">
        <span class="i-material-symbols:open-in-new"></span>
        新窗口
      </a>
      <a href={src} download
        class="flex items-center gap-1 rounded-lg px-3 py-2 text-sm font-medium transition-colors border border-(--border-color) hover:bg-(--primary) hover:text-white">
        <span class="i-material-symbols:download"></span>
        下载
      </a>
    </div>
  </div>
</div>
