---
interface Props {
  src: string;
  title?: string;
}

const { src, title = "PDF" } = Astro.props;
const viewerId = `pdfv-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="not-content pdf-card my-8 overflow-hidden rounded-xl border border-(--border-color) shadow-sm">
  <!-- 顶栏 -->
  <div class="flex items-center gap-2 border-b border-(--border-color) bg-(--card-bg) px-4 py-2.5 text-sm">
    <span class="i-material-symbols:description" style="font-size:1.2em;color:var(--primary)"></span>
    <span class="truncate font-medium">{title}</span>
    <div class="ml-auto flex items-center gap-1.5">
      <a href={src} target="_blank"
        class="flex items-center gap-1 rounded-md px-2.5 py-1 text-xs transition-colors border border-(--border-color) hover:bg-(--primary) hover:text-white">新窗口</a>
      <a href={src} download
        class="flex items-center gap-1 rounded-md px-2.5 py-1 text-xs transition-colors border border-(--border-color) hover:bg-(--primary) hover:text-white">下载</a>
    </div>
  </div>

  <!-- PDF.js canvas 渲染容器 -->
  <div id={viewerId} class="pdf-container" style="min-height:80vh;background:#525659;overflow-y:auto;position:relative;">
    <div class="pdf-loading" style="display:flex;align-items:center;justify-content:center;min-height:80vh;color:#999;font-size:0.9rem;flex-direction:column;gap:12px;">
      <div style="width:32px;height:32px;border:3px solid #444;border-top-color:#888;border-radius:50%;animation:pdf-spin 0.8s linear infinite;"></div>
      正在加载 PDF...
    </div>
  </div>
</div>

<style>
  @keyframes pdf-spin {
    to { transform: rotate(360deg); }
  }
</style>

<script>
  (function() {
    const id = "{viewerId}";
    const container = document.getElementById(id);
    if (!container) return;

    const card = container.closest(".pdf-card");
    const pdfUrl = card?.querySelector("a[href]")?.getAttribute("href") || "";

    (async () => {
      try {
        // 动态加载 PDF.js (从 CDN)
        const script = document.createElement("script");
        script.src = "https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js";
        await new Promise((resolve, reject) => {
          script.onload = resolve;
          script.onerror = reject;
          document.head.appendChild(script);
        });

        pdfjsLib.GlobalWorkerOptions.workerSrc = "https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js";

        const pdf = await pdfjsLib.getDocument(pdfUrl).promise;
        const totalPages = pdf.numPages;

        // 清除 loading
        container.innerHTML = "";

        // 顶部信息栏
        const info = document.createElement("div");
        Object.assign(info.style, {
          position: "sticky", top: "0", zIndex: "10",
          display: "flex", alignItems: "center", gap: "8px",
          padding: "8px 16px",
          background: "rgba(0,0,0,0.85)", color: "#fff",
          fontSize: "13px", backdropFilter: "blur(8px)",
        });
        info.innerHTML = `
          <span style="opacity:0.7;">${totalPages} 页</span>
          <span style="margin-left:auto;opacity:0.5;font-size:11px;">PDF.js</span>
        `;
        container.appendChild(info);

        // 渲染每一页
        const isMobile = window.innerWidth < 768;
        const scale = isMobile ? 0.6 : 1.3;
        const maxWidth = container.clientWidth - 32;

        for (let i = 1; i <= totalPages; i++) {
          const page = await pdf.getPage(i);
          let viewport = page.getViewport({ scale });

          // 自适应宽度
          if (viewport.width > maxWidth) {
            const adjScale = maxWidth / viewport.width;
            viewport = page.getViewport({ scale: adjScale });
          }

          const canvas = document.createElement("canvas");
          Object.assign(canvas.style, {
            display: "block", margin: "0 auto",
            boxShadow: "0 2px 12px rgba(0,0,0,0.3)",
            maxWidth: "100%",
          });
          canvas.width = viewport.width;
          canvas.height = viewport.height;

          const ctx = canvas.getContext("2d");
          await page.render({ canvasContext: ctx, viewport }).promise;

          const wrapper = document.createElement("div");
          wrapper.style.cssText = "padding:8px 0;text-align:center;";
          wrapper.appendChild(canvas);
          container.appendChild(wrapper);
        }
      } catch (err) {
        // PDF.js 失败 -> 降级到 iframe
        container.innerHTML = `<iframe src="${pdfUrl}" style="width:100%;height:80vh;border:none;display:block;background:#525659;" title="${title}"></iframe>`;
        console.warn("PDF.js failed, fell back to iframe:", err);
      }
    })();
  })();
</script>
